{
  "name": "2plus1",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:wsrelay": "bash ./scripts/dev-wsrelay.sh",
    "build": "vite build",
    "typecheck": "tsc -b",
    "preview": "vite preview",
    "relay:install": "npm --prefix relay-server install",
    "relay:dev": "npm --prefix relay-server run start",
    "deploy": "pnpm run build && gh-pages -d dist",
    "lint": "biome lint --write ./src",
    "format": "biome format --write ./src",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@react-three/fiber": "^9.4.0",
    "peerjs": "^1.5.5",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "three": "^0.181.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@biomejs/biome": "2.1.2",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@types/three": "^0.181.0",
    "@vitejs/plugin-react": "^4.7.0",
    "gh-pages": "^6.3.0",
    "rollup-plugin-visualizer": "^6.0.3",
    "typescript": "~5.8.3",
    "vite": "^7.0.5",
    "vitest": "^4.1.4"
  }
}
