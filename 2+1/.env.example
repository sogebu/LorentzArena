# 2+1 app env example
#
# Copy to `.env.local` and edit for your network.

# --- PeerJS / WebRTC ---
VITE_PEERJS_HOST=
VITE_PEERJS_PORT=
VITE_PEERJS_PATH=
VITE_PEERJS_SECURE=
VITE_PEERJS_DEBUG=3

# --- Dynamic TURN credentials (recommended for school/enterprise networks) ---
# URL of the Cloudflare Worker that issues short-lived TURN credentials.
# When set, the app fetches credentials on startup; static ICE_SERVERS below is ignored.
# See turn-worker/ for the Worker source and docs/NETWORKING.ja.md for details.
# VITE_TURN_CREDENTIAL_URL=https://lorentz-turn.<account>.workers.dev/
VITE_TURN_CREDENTIAL_URL=

# --- Static ICE config (JSON, fallback when TURN_CREDENTIAL_URL is unset) ---
# NOTE: Open Relay (openrelay.metered.ca) is blocked on some school networks.
# Prefer VITE_TURN_CREDENTIAL_URL above for reliable school/enterprise connectivity.
# VITE_WEBRTC_ICE_SERVERS='[
#   {"urls":["stun:stun.l.google.com:19302"]},
#   {"urls":["stun:stun.cloudflare.com:3478"]}
# ]'
VITE_WEBRTC_ICE_SERVERS=
VITE_WEBRTC_ICE_TRANSPORT_POLICY=

# --- Transport mode ---
# peerjs | wsrelay | auto
# auto = start with PeerJS and fallback to wsrelay when signaling fails
VITE_NETWORK_TRANSPORT=auto

# For wsrelay mode (or manual fallback in UI)
# Example (local): ws://localhost:8787
# Example (public 443/TLS): wss://relay.example.com
VITE_WS_RELAY_URL=
