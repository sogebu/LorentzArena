# 2+1 app env example
#
# Copy to `.env.local` and edit for your network.

# --- PeerJS / WebRTC ---
VITE_PEERJS_HOST=
VITE_PEERJS_PORT=
VITE_PEERJS_PATH=
VITE_PEERJS_SECURE=
VITE_PEERJS_DEBUG=3

# ICE config (JSON)
# Recommended for school/enterprise networks: free public TURN via Open Relay (Metered.ca).
# Credentials are public; safe to commit. See docs/NETWORKING.ja.md "A'" section.
# VITE_WEBRTC_ICE_SERVERS='[
#   {"urls":["stun:stun.l.google.com:19302"]},
#   {"urls":["stun:stun.cloudflare.com:3478"]},
#   {"urls":["turn:openrelay.metered.ca:80"],"username":"openrelayproject","credential":"openrelayproject"},
#   {"urls":["turns:openrelay.metered.ca:443?transport=tcp"],"username":"openrelayproject","credential":"openrelayproject"}
# ]'
VITE_WEBRTC_ICE_SERVERS=
VITE_WEBRTC_ICE_TRANSPORT_POLICY=

# --- Transport mode ---
# peerjs | wsrelay | auto
# auto = start with PeerJS and fallback to wsrelay when signaling fails
VITE_NETWORK_TRANSPORT=auto

# For wsrelay mode (or manual fallback in UI)
# Example (local): ws://localhost:8787
# Example (public 443/TLS): wss://relay.example.com
VITE_WS_RELAY_URL=
